<% const title = 'Dashboard'; %>

<div class="welcome-message">
	<h2 style="margin-bottom: 8px;">👋 Welcome, <%= user.full_name %>!</h2>
	<p>You are logged in as <strong><%= user.role.toUpperCase() %></strong></p>
</div>

<div class="card">
	<h2>📦 Recent Orders</h2>
	<% if (orders.length === 0) { %>
		<p style="color: #6b7280; text-align: center; padding: 32px;">No orders yet</p>
	<% } else { %>
		<table>
			<thead>
				<tr>
					<th>#ID</th>
					<th>Patient</th>
					<th>Item</th>
					<th>Room</th>
					<th>Status</th>
					<th>Created</th>
				</tr>
			</thead>
			<tbody>
				<% orders.forEach(o => { %>
				<tr>
					<td><strong>#<%= o.id %></strong></td>
					<td><%= o.patient_name %></td>
					<td><%= o.item_name %></td>
					<td><%= o.room_number || '-' %></td>
					<td><span class="badge <%= o.status %>"><%= o.status.replace(/_/g, ' ') %></span></td>
					<td><%= dayjs(o.created_at).format('MMM DD, HH:mm') %></td>
				</tr>
				<% }) %>
			</tbody>
		</table>
	<% } %>
</div>
