<% const title = 'Dashboard'; %>

<style>
	.dashboard-header {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.welcome-avatar {
		width: 80px;
		height: 80px;
		background: linear-gradient(135deg, #0066cc, #00a8b5);
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		font-size: 2rem;
	}

	.welcome-content h1 {
		font-size: 2rem;
		margin: 0 0 0.5rem 0;
		color: var(--text-primary);
	}

	.welcome-content p {
		margin: 0;
		color: var(--text-secondary);
	}

	.stats-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.stat-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		padding: 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.stat-icon {
		width: 50px;
		height: 50px;
		background: linear-gradient(135deg, #0066cc, #00a8b5);
		border-radius: 0.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 1.5rem;
		flex-shrink: 0;
	}

	.stat-content h3 {
		margin: 0;
		font-size: 0.9rem;
		color: var(--text-secondary);
		font-weight: 500;
	}

	.stat-value {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--primary);
		margin: 0.25rem 0 0 0;
	}

	.orders-section {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		overflow: hidden;
	}

	.section-header {
		padding: 1.5rem;
		border-bottom: 1px solid var(--border);
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-primary);
	}

	.section-header svg {
		width: 24px;
		height: 24px;
	}

	.empty-state {
		padding: 3rem 1.5rem;
		text-align: center;
		color: var(--text-secondary);
	}

	.empty-icon {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.orders-table-wrapper {
		overflow-x: auto;
	}

	.badge-status {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.4rem 0.75rem;
		border-radius: 0.35rem;
		font-size: 0.8rem;
		font-weight: 600;
		text-transform: capitalize;
	}

	.badge-status.placed {
		background: #e0f2fe;
		color: #0c4a6e;
	}

	.badge-status.in_kitchen {
		background: #fef3c7;
		color: #78350f;
	}

	.badge-status.out_for_delivery {
		background: #dbeafe;
		color: #1e40af;
	}

	.badge-status.delivered {
		background: #d1fae5;
		color: #065f46;
	}

	.badge-status.cancelled {
		background: #fee2e2;
		color: #7f1d1d;
	}

	@media (max-width: 768px) {
		.dashboard-header {
			flex-wrap: wrap;
		}

		.stats-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.welcome-content h1 {
			font-size: 1.5rem;
		}
	}
</style>

<!-- Welcome Section -->
<div class="dashboard-header">
	<div class="welcome-avatar">
		<%= user.full_name.charAt(0).toUpperCase() %>
	</div>
	<div class="welcome-content">
		<h1>Welcome back, <%= user.full_name %>!</h1>
		<p>You are logged in as <strong><%= user.role.toUpperCase() %></strong></p>
	</div>
</div>

<!-- Stats Cards -->
<div class="stats-grid">
	<div class="stat-card">
		<div class="stat-icon">📦</div>
		<div class="stat-content">
			<h3>Total Orders</h3>
			<div class="stat-value"><%= orders.length %></div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon">✓</div>
		<div class="stat-content">
			<h3>Delivered</h3>
			<div class="stat-value">
				<%= orders.filter(o => o.status === 'delivered').length %>
			</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon">👨‍🍳</div>
		<div class="stat-content">
			<h3>In Kitchen</h3>
			<div class="stat-value">
				<%= orders.filter(o => o.status === 'in_kitchen').length %>
			</div>
		</div>
	</div>

	<div class="stat-card">
		<div class="stat-icon">⏳</div>
		<div class="stat-content">
			<h3>Pending</h3>
			<div class="stat-value">
				<%= orders.filter(o => o.status === 'placed').length %>
			</div>
		</div>
	</div>
</div>

<!-- Recent Orders Section -->
<div class="orders-section">
	<div class="section-header">
		<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<circle cx="9" cy="21" r="1"></circle>
			<circle cx="20" cy="21" r="1"></circle>
			<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
		</svg>
		Recent Orders
	</div>

	<% if (orders.length === 0) { %>
		<div class="empty-state">
			<div class="empty-icon">📭</div>
			<p>No orders yet</p>
			<p style="font-size: 0.9rem; color: var(--text-tertiary);">Start by creating your first order</p>
		</div>
	<% } else { %>
		<div class="orders-table-wrapper">
			<table class="table">
				<thead>
					<tr>
						<th>Order ID</th>
						<th>Patient</th>
						<th>Item</th>
						<th>Room</th>
						<th>Status</th>
						<th>Created</th>
					</tr>
				</thead>
				<tbody>
					<% orders.slice(0, 10).forEach(o => { %>
					<tr>
						<td><strong>#<%= o.id %></strong></td>
						<td><%= o.patient_name %></td>
						<td><%= o.item_name %></td>
						<td><%= o.room_number || '-' %></td>
						<td>
							<span class="badge-status <%= o.status %>">
								<%= o.status.replace(/_/g, ' ') %>
							</span>
						</td>
						<td><%= dayjs(o.created_at).format('MMM DD, HH:mm') %></td>
					</tr>
					<% }) %>
				</tbody>
			</table>
		</div>
	<% } %>
</div>

