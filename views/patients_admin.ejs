<% const title = 'Patients'; %>

<style>
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 2rem;
	}

	.section-title {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-primary);
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.search-bar {
		display: flex;
		gap: 0.75rem;
		flex: 1;
		max-width: 400px;
	}

	.search-bar input {
		flex: 1;
		padding: 0.75rem 1rem;
		border: 1px solid var(--border);
		border-radius: 0.5rem;
		font-size: 0.95rem;
		transition: all 0.2s ease;
	}

	.search-bar input:focus {
		outline: none;
		border-color: var(--primary);
		box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
	}

	.patients-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
		gap: 1.5rem;
		margin-top: 1.5rem;
	}

	.patient-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		overflow: hidden;
		transition: all 0.3s ease;
		display: flex;
		flex-direction: column;
	}

	.patient-card:hover {
		border-color: var(--primary);
		box-shadow: var(--shadow-md);
		transform: translateY(-4px);
	}

	.patient-card-header {
		padding: 1.25rem;
		background: linear-gradient(135deg, #f8fafc, #f1f5f9);
		border-bottom: 1px solid var(--border);
	}

	.patient-avatar {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		font-weight: 700;
		font-size: 1.25rem;
		margin-bottom: 1rem;
	}

	.patient-name {
		font-size: 1.1rem;
		font-weight: 700;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}

	.patient-id {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.patient-card-body {
		padding: 1.25rem;
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.info-item {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 0.95rem;
	}

	.info-icon {
		color: var(--primary);
		min-width: 20px;
	}

	.info-label {
		font-weight: 600;
		color: var(--text-secondary);
		min-width: 70px;
	}

	.info-value {
		color: var(--text-primary);
	}

	.badge-group {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.badge-info {
		display: inline-block;
		padding: 0.4rem 0.8rem;
		background: #e0f2fe;
		color: #0369a1;
		border-radius: 0.35rem;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.badge-warning {
		display: inline-block;
		padding: 0.4rem 0.8rem;
		background: #fef3c7;
		color: #92400e;
		border-radius: 0.35rem;
		font-size: 0.75rem;
		font-weight: 600;
	}

	.patient-card-footer {
		padding: 1rem 1.25rem;
		background: var(--bg-card);
		border-top: 1px solid var(--border);
		display: flex;
		gap: 0.75rem;
	}

	.btn-action {
		flex: 1;
		padding: 0.6rem 0.75rem;
		border: none;
		border-radius: 0.35rem;
		font-size: 0.85rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
		text-align: center;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}

	.btn-action.edit {
		background: var(--primary);
		color: white;
	}

	.btn-action.edit:hover {
		background: var(--primary-dark);
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(0, 102, 204, 0.3);
	}

	.btn-action.delete {
		background: var(--danger);
		color: white;
	}

	.btn-action.delete:hover {
		background: #b91c1c;
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(220, 38, 38, 0.3);
	}

	.empty-state {
		text-align: center;
		padding: 3rem 2rem;
		background: var(--bg-card);
		border: 1px dashed var(--border);
		border-radius: 0.75rem;
		color: var(--text-secondary);
	}

	.empty-state-emoji {
		font-size: 3rem;
		margin-bottom: 1rem;
	}

	.empty-state-title {
		font-size: 1.1rem;
		font-weight: 600;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
	}

	@media (max-width: 768px) {
		.section-header {
			flex-direction: column;
			gap: 1rem;
			align-items: flex-start;
		}

		.search-bar {
			width: 100%;
		}

		.patients-grid {
			grid-template-columns: 1fr;
		}
	}
</style>

<!-- Section Header -->
<div class="section-header">
	<h1 class="section-title">
		<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
			<circle cx="8.5" cy="7" r="4"></circle>
			<path d="M20 8v6M23 11h-6"></path>
		</svg>
		Patients
	</h1>

	<a href="/admin/patients/new" class="btn btn-primary">
		<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<path d="M12 5v14M5 12h14"></path>
		</svg>
		New Patient
	</a>
</div>

<!-- Search Bar -->
<div class="search-bar">
	<input type="text" id="patientSearch" placeholder="Search by name or room number..." />
</div>

<!-- Patients Grid -->
<% if (patients.length === 0) { %>
<div class="empty-state">
	<div class="empty-state-emoji">🏥</div>
	<div class="empty-state-title">No Patients Found</div>
	<p>Start by adding the first patient to the system.</p>
</div>
<% } else { %>
<div class="patients-grid" id="patientsGrid">
	<% patients.forEach(p => { %>
	<div class="patient-card" data-search="<%= p.full_name.toLowerCase() %> <%= p.room_number %>">
		<!-- Card Header -->
		<div class="patient-card-header">
			<div class="patient-avatar"><%= p.full_name.charAt(0).toUpperCase() %></div>
			<div class="patient-name"><%= p.full_name %></div>
			<div class="patient-id">MRN: <%= p.mrn %></div>
		</div>

		<!-- Card Body -->
		<div class="patient-card-body">
			<!-- Room Info -->
			<div class="info-item">
				<span class="info-icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
						<polyline points="9 22 9 12 15 12 15 22"></polyline>
					</svg>
				</span>
				<span class="info-label">Room:</span>
				<span class="info-value"><%= p.room_number || 'N/A' %></span>
			</div>

			<!-- Ward Info -->
			<div class="info-item">
				<span class="info-icon">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M3 12h18M3 6h18M3 18h18"></path>
					</svg>
				</span>
				<span class="info-label">Ward:</span>
				<span class="info-value"><%= p.ward || 'General' %></span>
			</div>

			<!-- Dietary Restrictions -->
			<% if (p.dietary_restrictions) { %>
			<div>
				<div style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); margin-bottom: 0.35rem;">
					🥗 Dietary Restrictions
				</div>
				<div class="badge-group">
					<span class="badge-info"><%= p.dietary_restrictions %></span>
				</div>
			</div>
			<% } %>

			<!-- Allergies -->
			<% if (p.allergies) { %>
			<div>
				<div style="font-size: 0.85rem; font-weight: 600; color: var(--danger); margin-bottom: 0.35rem;">
					⚠️ Allergies
				</div>
				<div class="badge-group">
					<span class="badge-warning"><%= p.allergies %></span>
				</div>
			</div>
			<% } %>
		</div>

		<!-- Card Footer / Actions -->
		<div class="patient-card-footer">
			<a href="/admin/patients/<%= p.id %>/edit" class="btn-action edit">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
					<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
				</svg>
				Edit
			</a>
			<form method="post" action="/admin/patients/<%= p.id %>/delete" style="flex: 1;" onsubmit="return confirm('Are you sure you want to delete this patient?');">
				<button class="btn-action delete" type="submit" style="width: 100%;">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<polyline points="3 6 5 6 21 6"></polyline>
						<path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
						<line x1="10" y1="11" x2="10" y2="17"></line>
						<line x1="14" y1="11" x2="14" y2="17"></line>
					</svg>
					Delete
				</button>
			</form>
		</div>
	</div>
	<% }) %>
</div>
<% } %>

<!-- Search Functionality -->
<script>
	const searchInput = document.getElementById('patientSearch');
	const patientsGrid = document.getElementById('patientsGrid');

	if (searchInput && patientsGrid) {
		searchInput.addEventListener('input', (e) => {
			const searchTerm = e.target.value.toLowerCase();
			const cards = patientsGrid.querySelectorAll('.patient-card');

			cards.forEach(card => {
				const searchData = card.getAttribute('data-search');
				if (searchData.includes(searchTerm)) {
					card.style.display = '';
				} else {
					card.style.display = 'none';
				}
			});
		});
	}
</script>