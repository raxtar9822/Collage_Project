<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title><%= typeof title !== 'undefined' ? title : 'Hospital Meals' %></title>
	<link rel="stylesheet" href="/public/css/modern.css" />
</head>
<body>
	<!-- Modern Navigation Header -->
	<header class="navbar">
		<div class="navbar-container">
			<!-- Logo & Brand -->
			<div class="navbar-brand">
				<a href="/" class="brand-link">
					<svg class="brand-icon" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg">
						<rect width="40" height="40" rx="8" fill="#0066cc"/>
						<path d="M12 18C12 16.9 12.9 16 14 16H26C27.1 16 28 16.9 28 18V26C28 27.1 27.1 28 26 28H14C12.9 28 12 27.1 12 26V18Z" fill="white"/>
						<circle cx="20" cy="22" r="2" fill="#0066cc"/>
					</svg>
					<span class="brand-text">Hospital Meals</span>
				</a>
			</div>

			<!-- Navigation Links -->
			<nav class="navbar-menu">
				<% if (user) { %>
					<a href="/dashboard" class="nav-link">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
							<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
						</svg>
						Dashboard
					</a>
					<% if (user.role === 'receptionist') { %>
						<a href="/receptionist/tiffin-orders" class="nav-link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M6 9l12 0M6 9l1.5 12a2 2 0 0 0 2 1.68h8a2 2 0 0 0 2-1.68L18 9"></path>
							</svg>
							Orders
						</a>
					<% } else { %>
						<a href="/orders" class="nav-link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<circle cx="9" cy="21" r="1"></circle>
								<circle cx="20" cy="21" r="1"></circle>
								<path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
							</svg>
							Orders
						</a>
						<a href="/menu" class="nav-link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M2 5l20 0M2 12l20 0M2 19l20 0"></path>
							</svg>
							Menu
						</a>
					<% } %>
					<% if (user.role === 'admin') { %>
						<a href="/admin/patients" class="nav-link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
								<circle cx="12" cy="7" r="4"></circle>
							</svg>
							Patients
						</a>
						<a href="/admin/reports" class="nav-link">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
								<polyline points="9 22 9 12 15 12 15 22"></polyline>
							</svg>
							Reports
						</a>
					<% } %>
				<% } %>
			</nav>

			<!-- User Section -->
			<div class="navbar-right">
				<% if (user) { %>
					<div class="user-info">
						<div class="user-avatar">
							<%= user.full_name.charAt(0).toUpperCase() %>
						</div>
						<div class="user-details">
							<div class="user-name"><%= user.full_name %></div>
							<div class="user-role"><%= user.role %></div>
						</div>
					</div>
					<form method="post" action="/logout" class="logout-form">
						<button type="submit" class="btn-logout">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
								<polyline points="16 17 21 12 16 7"></polyline>
								<line x1="21" y1="12" x2="9" y2="12"></line>
							</svg>
							Logout
						</button>
					</form>
				<% } %>
			</div>
		</div>
	</header>

	<!-- Main Content -->
	<main class="main-content">
		<div class="content-container">
			<%- body %>
		</div>
	</main>

	<!-- Notifications -->
	<div id="notif-stack" class="notification-stack"></div>

	<!-- Scripts -->
	<script src="/socket.io/socket.io.js"></script>
	<script src="/public/js/notifications.js"></script>
	<script>
		const socket = window.socket || io();
		window.socket = socket;
		socket.on('orders:updated', (payload) => {
			if (location.pathname.includes('/orders') || location.pathname.includes('/dashboard')) {
				location.reload();
			}
		});
	</script>
</body>
</html>
