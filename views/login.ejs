<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Hospital Meals • Login</title>
	<style>
		* {
			margin: 0;
			padding: 0;
			box-sizing: border-box;
		}

		html, body {
			height: 100%;
			font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
		}

		body {
			background: linear-gradient(135deg, #e0f2fe 0%, #c7e9f9 100%);
			min-height: 100vh;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 20px;
		}

		.login-container {
			width: 100%;
			max-width: 420px;
			display: flex;
			flex-direction: column;
			align-items: center;
		}

		/* Logo Section */
		.logo-section {
			text-align: center;
			margin-bottom: 2.5rem;
			animation: slideDown 0.6s ease;
		}

		@keyframes slideDown {
			from {
				opacity: 0;
				transform: translateY(-30px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.logo-wrapper {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 0.5rem;
			margin-bottom: 1rem;
		}

		.logo-icon {
			width: 50px;
			height: 50px;
			background: linear-gradient(135deg, #0066cc 0%, #00a8b5 100%);
			border-radius: 12px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.8rem;
			box-shadow: 0 4px 12px rgba(0, 102, 204, 0.2);
		}

		.logo-title {
			font-size: 2rem;
			font-weight: 700;
			color: #0066cc;
			letter-spacing: -0.02em;
		}

		.logo-subtitle {
			font-size: 0.95rem;
			color: #64748b;
			margin-top: 0.5rem;
			font-weight: 500;
		}

		/* Login Card */
		.login-card {
			width: 100%;
			background: white;
			border-radius: 16px;
			padding: 2.5rem 2rem;
			box-shadow: 0 10px 30px rgba(0, 102, 204, 0.12);
			animation: fadeIn 0.6s ease 0.1s both;
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(10px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.form-header {
			margin-bottom: 2rem;
			text-align: center;
		}

		.form-title {
			font-size: 1.5rem;
			font-weight: 700;
			color: #1e293b;
			margin-bottom: 0.5rem;
		}

		.form-subtitle {
			color: #64748b;
			font-size: 0.9rem;
		}

		/* Role Toggle - Horizontal Tabs */
		.role-tabs {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.5rem;
			margin-bottom: 2rem;
			background: #f8fafc;
			padding: 0.3rem;
			border-radius: 10px;
		}

		.tab-btn {
			padding: 0.7rem 1rem;
			border: none;
			background: transparent;
			color: #64748b;
			font-size: 0.9rem;
			font-weight: 600;
			cursor: pointer;
			border-radius: 8px;
			transition: all 0.3s ease;
			position: relative;
		}

		.tab-btn.active {
			color: white;
			background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
			box-shadow: 0 4px 12px rgba(0, 102, 204, 0.2);
		}

		.tab-btn:hover:not(.active) {
			color: #0066cc;
			background: rgba(0, 102, 204, 0.05);
		}

		/* Alert */
		.alert {
			background: #fee2e2;
			border: 1px solid #fecaca;
			color: #991b1b;
			padding: 1rem;
			border-radius: 10px;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: flex-start;
			gap: 0.75rem;
			animation: slideDown 0.3s ease;
		}

		.alert-icon {
			font-size: 1.2rem;
			flex-shrink: 0;
		}

		/* Form Group */
		.form-group {
			margin-bottom: 1.3rem;
		}

		.form-label {
			display: block;
			font-weight: 600;
			color: #1e293b;
			font-size: 0.9rem;
			margin-bottom: 0.6rem;
		}

		.form-input {
			width: 100%;
			padding: 0.9rem 1rem;
			border: 2px solid #e0e9f0;
			border-radius: 10px;
			font-size: 0.95rem;
			color: #1e293b;
			font-family: inherit;
			transition: all 0.2s ease;
			background-color: white;
		}

		.form-input:focus {
			outline: none;
			border-color: #0066cc;
			background-color: #f8fafc;
			box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
		}

		.form-input::placeholder {
			color: #94a3b8;
		}

		/* Checkboxes Row */
		.checkbox-row {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rev;
			margin-bottom: 1.8rem;
			margin-top: 1.2rem;
		}

		.form-checkbox {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			cursor: pointer;
		}

		.form-checkbox input[type="checkbox"] {
			width: 18px;
			height: 18px;
			cursor: pointer;
			accent-color: #0066cc;
			border-radius: 4px;
		}

		.checkbox-label {
			font-size: 0.9rem;
			color: #64748b;
			cursor: pointer;
			user-select: none;
		}

		/* Submit Button - Enhanced with Glow */
		.btn-login {
			width: 100%;
			padding: 1rem 1.5rem;
			border: none;
			background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
			color: white;
			font-size: 1rem;
			font-weight: 600;
			border-radius: 10px;
			cursor: pointer;
			transition: all 0.3s ease;
			box-shadow: 0 6px 20px rgba(0, 102, 204, 0.2);
			position: relative;
			overflow: hidden;
		}

		.btn-login::before {
			content: '';
			position: absolute;
			top: 0;
			left: -100%;
			width: 100%;
			height: 100%;
			background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
			transition: left 0.5s ease;
		}

		.btn-login:hover {
			transform: translateY(-3px);
			box-shadow: 0 10px 30px rgba(0, 102, 204, 0.35);
		}

		.btn-login:hover::before {
			left: 100%;
		}

		.btn-login:active {
			transform: translateY(-1px);
			box-shadow: 0 4px 12px rgba(0, 102, 204, 0.25);
		}

		/* Demo Credentials & Footer */
		.demo-section {
			margin-top: 1.8rem;
			padding-top: 1.5rem;
			border-top: 1px solid #e2e8f0;
		}

		.demo-title {
			font-size: 0.8rem;
			font-weight: 600;
			color: #94a3b8;
			text-transform: uppercase;
			letter-spacing: 0.05em;
			margin-bottom: 0.8rem;
		}

		.demo-cred {
			font-size: 0.8rem;
			color: #94a3b8;
			margin-bottom: 0.4rem;
			font-family: 'Monaco', 'Courier New', monospace;
		}

		.demo-cred strong {
			color: #1e293b;
			font-weight: 600;
		}

		/* Footer Link */
		.login-footer {
			text-align: center;
			margin-top: 1.5rem;
			padding-top: 1.5rem;
			border-top: 1px solid #e2e8f0;
		}

		.footer-link {
			text-decoration: none;
			color: #0066cc;
			font-size: 0.9rem;
			font-weight: 500;
			transition: all 0.2s ease;
			display: inline-block;
		}

		.footer-link:hover {
			color: #0052a3;
			text-decoration: underline;
		}

		/* Accessibility - High Contrast */
		.form-input:focus,
		.tab-btn:focus-visible {
			outline: 2px solid #0066cc;
			outline-offset: 2px;
		}

		/* Responsive Design - Mobile First */
		@media (max-width: 480px) {
			body {
				padding: 16px;
			}

			.login-container {
				max-width: 100%;
			}

			.logo-section {
				margin-bottom: 2rem;
			}

			.logo-title {
				font-size: 1.75rem;
			}

			.logo-icon {
				width: 45px;
				height: 45px;
				font-size: 1.5rem;
			}

			.login-card {
				padding: 2rem 1.5rem;
				border-radius: 14px;
			}

			.form-title {
				font-size: 1.3rem;
			}

			.form-subtitle {
				font-size: 0.85rem;
			}

			.checkbox-row {
				grid-template-columns: 1fr;
				gap: 0.8rem;
			}

			.btn-login {
				padding: 0.9rem 1.5rem;
				font-size: 0.95rem;
			}

			.demo-section {
				margin-top: 1.5rem;
				padding-top: 1.2rem;
			}

			.login-footer {
				margin-top: 1.2rem;
				padding-top: 1.2rem;
			}
		}

		/* Tablet Optimization */
		@media (min-width: 481px) and (max-width: 768px) {
			.login-card {
				padding: 2.2rem 1.8rem;
			}

			.logo-title {
				font-size: 1.9rem;
			}
		}

		/* Desktop View */
		@media (min-width: 769px) {
			.login-title {
				font-size: 2.2rem;
			}
		}
	</style>
</head>
<body>
	<div class="login-container">
		<!-- Logo & Header Section -->
		<div class="logo-section">
			<div class="logo-wrapper">
				<div class="logo-icon">🏥</div>
				<h1 class="logo-title">Hospital Meals</h1>
			</div>
			<p class="logo-subtitle">Management Portal</p>
		</div>

		<!-- Login Card -->
		<div class="login-card">
			<!-- Form Header -->
			<div class="form-header">
				<h2 class="form-title" id="formTitle">Sign In</h2>
				<p class="form-subtitle" id="formSubtitle">Enter your credentials to continue</p>
			</div>

			<!-- Error Alert -->
			<% if (typeof error !== 'undefined' && error) { %>
				<div class="alert">
					<div class="alert-icon">⚠️</div>
					<div><%= error %></div>
				</div>
			<% } %>

			<!-- Role Selection Tabs -->
			<div class="role-tabs">
				<button type="button" class="tab-btn active" id="btn-mess" data-role="mess">
					🍽 Mess Owner
				</button>
				<button type="button" class="tab-btn" id="btn-hospital" data-role="hospital">
					🏥 Hospital Staff
				</button>
			</div>

			<!-- Login Form -->
			<form id="loginForm" method="POST" action="/login/mess" novalidate>
				<!-- Username Field -->
				<div class="form-group">
					<label for="username" class="form-label">Username</label>
					<input
						id="username"
						name="username"
						type="text"
						class="form-input"
						placeholder="Hospital User"
						autocomplete="username"
						required
						aria-required="true"
					>
				</div>

				<!-- Password Field -->
				<div class="form-group">
					<label for="password" class="form-label">Password</label>
					<input
						id="password"
						name="password"
						type="password"
						class="form-input"
						placeholder="Enter your password"
						autocomplete="current-password"
						required
						aria-required="true"
					>
				</div>

				<!-- Checkbox Row - Remember Me & Secure Login -->
				<div class="checkbox-row">
					<label class="form-checkbox">
						<input type="checkbox" name="remember_me" id="remember_me" aria-label="Remember me on this device">
						<span class="checkbox-label">Remember Me</span>
					</label>
					<label class="form-checkbox">
						<input type="checkbox" name="secure_login" id="secure_login" checked aria-label="Enable secure login">
						<span class="checkbox-label">Secure Login</span>
					</label>
				</div>

				<!-- Sign In Button with Glow -->
				<button class="btn-login" type="submit" aria-label="Sign in to Hospital Meals">
					Sign In
				</button>

				<!-- Demo Credentials -->
				<div class="demo-section">
					<div class="demo-title">Demo Credentials</div>
					<div class="demo-cred">
						<strong>Admin:</strong> messowner / mess123
					</div>
					<div class="demo-cred">
						<strong>Nurse:</strong> nurse1 / nurse123
					</div>
					<div class="demo-cred">
						<strong>Kitchen:</strong> kitchen1 / kitchen123
					</div>
				</div>

				<!-- Footer Link -->
				<div class="login-footer">
					<a href="#reset-credentials" class="footer-link" aria-label="Reset your credentials">
						Reset Credentials?
					</a>
				</div>
			</form>
		</div>
	</div>

	<script>
		const loginForm = document.getElementById('loginForm');
		const formTitle = document.getElementById('formTitle');
		const formSubtitle = document.getElementById('formSubtitle');
		const btnMess = document.getElementById('btn-mess');
		const btnHospital = document.getElementById('btn-hospital');
		const usernameInput = document.getElementById('username');
		const passwordInput = document.getElementById('password');
		const defaultType = '<%= errorType === "hospital" ? "hospital" : "mess" %>';

		const roleTitles = {
			mess: { title: 'Mess Owner Login', subtitle: 'Manage meal services and inventory' },
			hospital: { title: 'Hospital Staff Login', subtitle: 'Order and manage patient meals' }
		};

		const rolePlaceholders = {
			mess: { username: 'messowner', password: 'Password' },
			hospital: { username: 'nurse1', password: 'Password' }
		};

		function setMode(type) {
			const isMess = type === 'mess';
			
			// Update tabs
			btnMess.classList.toggle('active', isMess);
			btnHospital.classList.toggle('active', !isMess);
			
			// Update form action
			loginForm.action = isMess ? '/login/mess' : '/login/hospital';
			
			// Update text
			formTitle.textContent = roleTitles[type].title;
			formSubtitle.textContent = roleTitles[type].subtitle;
			
			// Update placeholders
			usernameInput.placeholder = `e.g., ${rolePlaceholders[type].username}`;
			passwordInput.placeholder = rolePlaceholders[type].password;
		}

		// Tab click handlers
		btnMess.addEventListener('click', () => setMode('mess'));
		btnHospital.addEventListener('click', () => setMode('hospital'));

		// Initialize with default mode
		setMode(defaultType);
	</script>
</body>
</html>

