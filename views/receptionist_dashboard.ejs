<% const title = 'Receptionist Dashboard'; %>

<div class="welcome-message">
	<h2 style="margin-bottom: 8px;">📋 Tiffin Orders</h2>
	<p>Manage daily tiffin orders for patients</p>
</div>

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 12px; margin-bottom: 24px;">
	<div class="card" style="text-align: center; padding: 16px;">
		<div style="font-size: 28px; font-weight: bold; color: #3b82f6;"><%= orders.filter(o => o.status === 'pending').length %></div>
		<div style="color: #6b7280; font-size: 12px;">Pending</div>
	</div>
	<div class="card" style="text-align: center; padding: 16px;">
		<div style="font-size: 28px; font-weight: bold; color: #10b981;"><%= orders.filter(o => o.status === 'confirmed').length %></div>
		<div style="color: #6b7280; font-size: 12px;">Confirmed</div>
	</div>
	<div class="card" style="text-align: center; padding: 16px;">
		<div style="font-size: 28px; font-weight: bold; color: #f59e0b;"><%= orders.filter(o => o.status === 'preparing').length %></div>
		<div style="color: #6b7280; font-size: 12px;">Preparing</div>
	</div>
	<div class="card" style="text-align: center; padding: 16px;">
		<div style="font-size: 28px; font-weight: bold; color: #8b5cf6;"><%= orders.length %></div>
		<div style="color: #6b7280; font-size: 12px;">Total</div>
	</div>
</div>

<div style="display: flex; gap: 12px; margin-bottom: 24px;">
	<a href="/receptionist/tiffin-orders/new" style="flex: 1;"><button style="width: 100%; background-color: #3b82f6;">+ New Order</button></a>
	<a href="/receptionist/tiffin-orders"><button style="flex: 1; background-color: #6b7280;">View All</button></a>
</div>

<div class="card">
	<h2>Recent Tiffin Orders</h2>
	<% if (orders.length === 0) { %>
		<p style="color: #6b7280; text-align: center; padding: 32px;">No tiffin orders yet. <a href="/receptionist/tiffin-orders/new">Create one</a></p>
	<% } else { %>
		<table>
			<thead>
				<tr>
					<th>Patient</th>
					<th>Ward</th>
					<th>Food</th>
					<th>Qty</th>
					<th>Status</th>
					<th>Actions</th>
				</tr>
			</thead>
			<tbody>
				<% orders.slice(0, 10).forEach(order => { %>
				<tr>
					<td><strong><%= order.patient_name %></strong></td>
					<td><%= order.ward %></td>
					<td><%= order.food_type %></td>
					<td><%= order.quantity %></td>
					<td><span class="badge <%= order.status %>"><%= order.status %></span></td>
					<td>
						<a href="/receptionist/tiffin-orders/<%= order.id %>/edit"><button style="padding: 4px 8px; font-size: 12px;">Edit</button></a>
						<form method="post" action="/receptionist/tiffin-orders/<%= order.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this order?')">
							<button type="submit" style="padding: 4px 8px; font-size: 12px; background-color: #ef4444; color: white;">Delete</button>
						</form>
					</td>
				</tr>
				<% }) %>
			</tbody>
		</table>
	<% } %>
</div>


