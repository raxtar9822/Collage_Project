<% const title = 'Reports & Analytics'; %>

<style>
	.reports-header {
		margin-bottom: 2rem;
	}

	.reports-title {
		font-size: 1.75rem;
		font-weight: 700;
		color: var(--text-primary);
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1.5rem;
	}

	.export-buttons {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.btn-export {
		padding: 0.6rem 1.25rem;
		border: none;
		border-radius: 0.5rem;
		font-size: 0.9rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
		text-decoration: none;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}

	.btn-export.csv {
		background: linear-gradient(135deg, #10b981, #059669);
		color: white;
	}

	.btn-export.csv:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(16, 185, 129, 0.4);
	}

	.btn-export.pdf {
		background: linear-gradient(135deg, #ef4444, #dc2626);
		color: white;
	}

	.btn-export.pdf:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4);
	}

	.btn-export.xlsx {
		background: linear-gradient(135deg, #3b82f6, #1d4ed8);
		color: white;
	}

	.btn-export.xlsx:hover {
		transform: translateY(-2px);
		box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
	}

	.charts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.chart-card {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 0.75rem;
		padding: 1.5rem;
		transition: all 0.3s ease;
	}

	.chart-card:hover {
		border-color: var(--primary);
		box-shadow: var(--shadow-md);
	}

	.chart-card-header {
		margin-bottom: 1.25rem;
	}

	.chart-title {
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--text-primary);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		margin-bottom: 0.5rem;
	}

	.chart-subtitle {
		font-size: 0.85rem;
		color: var(--text-secondary);
	}

	.chart-container {
		position: relative;
		height: 280px;
	}

	.chart-container canvas {
		max-height: 100%;
	}

	@media (max-width: 1024px) {
		.charts-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 768px) {
		.reports-title {
			font-size: 1.5rem;
		}

		.export-buttons {
			flex-direction: column;
		}

		.btn-export {
			width: 100%;
			justify-content: center;
		}
	}
</style>

<!-- Header -->
<div class="reports-header">
	<h1 class="reports-title">
		<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<line x1="12" y1="2" x2="12" y2="22"></line>
			<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
		</svg>
		Reports & Analytics
	</h1>

	<div class="export-buttons">
		<a href="/admin/reports/export.csv" class="btn-export csv">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
				<polyline points="7 10 12 15 17 10"></polyline>
				<line x1="12" y1="15" x2="12" y2="3"></line>
			</svg>
			Export CSV
		</a>
		<a href="/admin/reports/export.pdf" class="btn-export pdf">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
				<polyline points="7 10 12 15 17 10"></polyline>
				<line x1="12" y1="15" x2="12" y2="3"></line>
			</svg>
			Export PDF
		</a>
		<a href="/admin/reports/export.xlsx" class="btn-export xlsx">
			<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
				<polyline points="7 10 12 15 17 10"></polyline>
				<line x1="12" y1="15" x2="12" y2="3"></line>
			</svg>
			Export Excel
		</a>
	</div>
</div>

<!-- Charts Grid -->
<div class="charts-grid">
	<!-- Daily Meal Counts Chart -->
	<div class="chart-card">
		<div class="chart-card-header">
			<div class="chart-title">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline>
					<polyline points="17 6 23 6 23 12"></polyline>
				</svg>
				Daily Meal Counts
			</div>
			<div class="chart-subtitle">Last 14 days trend</div>
		</div>
		<div class="chart-container">
			<canvas id="chartDaily"></canvas>
		</div>
	</div>

	<!-- Weekly Meal Counts Chart -->
	<div class="chart-card">
		<div class="chart-card-header">
			<div class="chart-title">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
					<line x1="16" y1="2" x2="16" y2="6"></line>
					<line x1="8" y1="2" x2="8" y2="6"></line>
					<line x1="3" y1="10" x2="21" y2="10"></line>
				</svg>
				Weekly Meal Counts
			</div>
			<div class="chart-subtitle">Last 8 weeks summary</div>
		</div>
		<div class="chart-container">
			<canvas id="chartWeekly"></canvas>
		</div>
	</div>

	<!-- Most Requested Dishes Chart -->
	<div class="chart-card">
		<div class="chart-card-header">
			<div class="chart-title">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M6 9l6 6 6-6"></path>
					<path d="M3 5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5z"></path>
				</svg>
				Top Dishes
			</div>
			<div class="chart-subtitle">Most requested items</div>
		</div>
		<div class="chart-container">
			<canvas id="chartTop"></canvas>
		</div>
	</div>

	<!-- Orders by Dietary Restriction Chart -->
	<div class="chart-card">
		<div class="chart-card-header">
			<div class="chart-title">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<circle cx="12" cy="12" r="10"></circle>
					<polyline points="12 6 12 12 16 14"></polyline>
				</svg>
				Dietary Distribution
			</div>
			<div class="chart-subtitle">Orders by dietary restriction</div>
		</div>
		<div class="chart-container">
			<canvas id="chartDiet"></canvas>
		</div>
	</div>
</div>

<!-- Waste by Ward Chart (Full Width) -->
<div class="chart-card" style="margin-bottom: 2rem;">
	<div class="chart-card-header">
		<div class="chart-title">
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
				<polyline points="9 22 9 12 15 12 15 22"></polyline>
			</svg>
			Waste Analysis
		</div>
		<div class="chart-subtitle">Daily waste percentage by ward</div>
	</div>
	<div class="chart-container" style="height: 320px;">
		<canvas id="chartWaste"></canvas>
	</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
	(function(){
		// Color palette
		const colors = {
			primary: '#0066cc',
			secondary: '#00a8b5',
			success: '#10b981',
			warning: '#f59e0b',
			danger: '#dc2626',
			info: '#3b82f6',
			light: '#e2e8f0',
			grid: 'rgba(226, 232, 240, 0.3)'
		};

		const chartOptions = {
			responsive: true,
			maintainAspectRatio: false,
			plugins: {
				legend: {
					labels: {
						usePointStyle: true,
						padding: 15,
						font: { size: 12, weight: '600' },
						color: '#4b5563'
					}
				},
				tooltip: {
					backgroundColor: 'rgba(0, 0, 0, 0.8)',
					titleFont: { size: 13, weight: '600' },
					bodyFont: { size: 12 },
					padding: 12,
					borderRadius: 8,
					titleMarginBottom: 8
				}
			},
			interaction: {
				intersect: false,
				mode: 'index'
			}
		};

		var daily = <%- JSON.stringify(daily) %>;
		var weekly = <%- JSON.stringify(weekly) %>;
		var topDishes = <%- JSON.stringify(topDishes) %>;
		var byDiet = <%- JSON.stringify(byDiet) %>;
		var wasteByWardDaily = <%- JSON.stringify(wasteByWardDaily) %>;

		// Daily Line Chart
		new Chart(document.getElementById('chartDaily'), {
			type: 'line',
			data: {
				labels: daily.map(d => d.day),
				datasets: [{
					label: 'Meals Served',
					data: daily.map(d => d.count),
					borderColor: colors.primary,
					backgroundColor: 'rgba(0, 102, 204, 0.08)',
					borderWidth: 3,
					fill: true,
					tension: 0.4,
					pointBackgroundColor: colors.primary,
					pointBorderColor: '#fff',
					pointRadius: 5,
					pointHoverRadius: 7,
					pointBorderWidth: 2
				}]
			},
			options: {
				...chartOptions,
				scales: {
					y: {
						beginAtZero: true,
						ticks: {
							precision: 0,
							color: '#6b7280'
						},
						grid: { color: colors.grid, drawBorder: false },
						border: { display: false }
					},
					x: {
						ticks: { color: '#6b7280' },
						grid: { display: false },
						border: { display: false }
					}
				}
			}
		});

		// Weekly Line Chart
		new Chart(document.getElementById('chartWeekly'), {
			type: 'line',
			data: {
				labels: weekly.map(d => d.week),
				datasets: [{
					label: 'Weekly Meals',
					data: weekly.map(d => d.count),
					borderColor: colors.secondary,
					backgroundColor: 'rgba(0, 168, 181, 0.08)',
					borderWidth: 3,
					fill: true,
					tension: 0.4,
					pointBackgroundColor: colors.secondary,
					pointBorderColor: '#fff',
					pointRadius: 5,
					pointHoverRadius: 7,
					pointBorderWidth: 2
				}]
			},
			options: {
				...chartOptions,
				scales: {
					y: {
						beginAtZero: true,
						ticks: {
							precision: 0,
							color: '#6b7280'
						},
						grid: { color: colors.grid, drawBorder: false },
						border: { display: false }
					},
					x: {
						ticks: { color: '#6b7280' },
						grid: { display: false },
						border: { display: false }
					}
				}
			}
		});

		// Top Dishes Bar Chart
		new Chart(document.getElementById('chartTop'), {
			type: 'bar',
			data: {
				labels: topDishes.map(d => d.item_name),
				datasets: [{
					label: 'Orders',
					data: topDishes.map(d => d.count),
					backgroundColor: [
						'#0066cc', '#00a8b5', '#10b981', '#f59e0b',
						'#3b82f6', '#8b5cf6', '#ec4899', '#ef4444',
						'#f97316', '#06b6d4'
					],
					borderRadius: 6,
					borderSkipped: false,
					hoverBackgroundColor: [
						'#0052a3', '#00a8b5', '#059669', '#d97706',
						'#1d4ed8', '#7c3aed', '#be185d', '#dc2626',
						'#ea580c', '#0891b2'
					]
				}]
			},
			options: {
				...chartOptions,
				indexAxis: 'y',
				scales: {
					x: {
						beginAtZero: true,
						ticks: {
							precision: 0,
							color: '#6b7280'
						},
						grid: { color: colors.grid, drawBorder: false },
						border: { display: false }
					},
					y: {
						ticks: { color: '#6b7280' },
						grid: { display: false },
						border: { display: false }
					}
				}
			}
		});

		// Dietary Pie Chart
		new Chart(document.getElementById('chartDiet'), {
			type: 'doughnut',
			data: {
				labels: byDiet.map(d => d.restriction),
				datasets: [{
					data: byDiet.map(d => d.count),
					backgroundColor: [
						'#0066cc', '#00a8b5', '#10b981', '#f59e0b',
						'#3b82f6', '#8b5cf6', '#ec4899', '#ef4444'
					],
					borderColor: '#fff',
					borderWidth: 3
				}]
			},
			options: {
				...chartOptions,
				plugins: {
					...chartOptions.plugins,
					legend: {
						...chartOptions.plugins.legend,
						position: 'bottom'
					}
				}
			}
		});

		// Waste by Ward Stacked Bar Chart
		(function(){
			var days = Array.from(new Set(wasteByWardDaily.map(d => d.day)));
			var wards = Array.from(new Set(wasteByWardDaily.map(d => d.ward)));
			var colorPool = ['#ef4444', '#f59e0b', '#10b981', '#3b82f6', '#8b5cf6', '#ec4899'];
			var datasets = wards.map(function(ward, i){
				var color = colorPool[i % colorPool.length];
				return {
					label: ward,
					backgroundColor: color,
					borderRadius: 4,
					borderSkipped: false,
					data: days.map(function(day){
						var rec = wasteByWardDaily.find(function(r){ return r.day === day && r.ward === ward; });
						return rec ? Number(rec.waste_percent) : 0;
					})
				};
			});

			new Chart(document.getElementById('chartWaste'), {
				type: 'bar',
				data: {
					labels: days,
					datasets: datasets
				},
				options: {
					...chartOptions,
					scales: {
						x: {
							stacked: true,
							ticks: { color: '#6b7280' },
							grid: { display: false },
							border: { display: false }
						},
						y: {
							stacked: true,
							beginAtZero: true,
							ticks: {
								color: '#6b7280',
								callback: function(v){ return v + '%'; }
							},
							grid: { color: colors.grid, drawBorder: false },
							border: { display: false }
						}
					}
				}
			});
		})();
	})();
</script>


